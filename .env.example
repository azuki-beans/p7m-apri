# Copia in .env e personalizza per il deploy.

# Chiave segreta Django — OBBLIGATORIA in produzione.
# Genera con: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=

# Porta esposta sull'host (il container ascolta sempre su 8000).
PORT=8000

# Host/domini consentiti, separati da virgola (es. p7m.azienda.it).
DJANGO_ALLOWED_HOSTS=*

# Origini fidate per CSRF, separate da virgola, con schema (es. https://p7m.azienda.it).
CSRF_TRUSTED_ORIGINS=
